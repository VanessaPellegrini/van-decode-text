{
  "name": "@van/decode-text",
  "version": "1.0.0",
  "description": "React component that decodes binary text with a hacker-terminal scramble effect",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "react",
    "text-animation",
    "decode",
    "binary",
    "scramble",
    "hacker",
    "terminal",
    "text-effect",
    "decode-text"
  ],
  "license": "MIT",
  "author": "Vanessa Pellegrini",
  "repository": {
    "type": "git",
    "url": "https://github.com/VanessaPellegrini/decode-text"
  }
}
